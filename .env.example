APP_NAME=Ranga
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=bn
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Asia/Dhaka

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Ranga white-label ---
RANGA_BRAND_NAME="Ranga"
RANGA_BRAND_TAGLINE="Dresses that speak your colour"
RANGA_BRAND_COLOR="#e11d48"
RANGA_DEFAULT_LOCALE=bn
RANGA_FALLBACK_LOCALE=en
RANGA_DEFAULT_TIMEZONE=Asia/Dhaka
RANGA_CURRENCY=BDT
RANGA_CURRENCY_SYMBOL="৳"
SANCTUM_TOKEN_EXPIRATION=43200

# --- Search (Laravel Scout + Meilisearch) ---
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# --- Image optimisation (imgproxy) ---
RANGA_IMAGE_DRIVER=imgproxy
IMGPROXY_URL=https://img.ranga.test
IMGPROXY_KEY=
IMGPROXY_SALT=
RANGA_IMAGE_SOURCE_BASE=
RANGA_IMAGE_FORMAT=webp

# --- AI providers ---
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Notification senders (log driver by default) ---
SMS_DRIVER=log
WHATSAPP_DRIVER=log
PUSH_DRIVER=log

# --- Payment gateways ---
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=true
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_SANDBOX=true
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# --- OAuth providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=
